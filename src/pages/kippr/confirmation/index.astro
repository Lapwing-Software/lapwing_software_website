---
import '../../../styles/global.css';
---

<!doctype html>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
    <link rel='icon' href='/favicon.ico' />
    <title>Kippr | Email Confirmed</title>
  </head>
  <body class='min-h-screen bg-[#F3F5F3] px-5 py-10 sm:px-6 sm:py-16'>
    <main
      class='mx-auto flex min-h-[calc(100vh-5rem)] max-w-3xl items-center justify-center p-0 sm:min-h-[calc(100vh-8rem)]'
    >
      <section
        class='w-full max-w-xl overflow-hidden rounded-xl bg-[#F9F9F9] shadow-[0_4px_12px_rgba(0,0,0,0.05)]'
      >
        <div class='px-6 pt-10 sm:px-8'>
          <img
            src='https://wsbdhmmxvrudlzbiyzdg.supabase.co/storage/v1/object/sign/logos/logoLapwareLight.png?token=eyJraWQiOiJzdG9yYWdlLXVybC1zaWduaW5nLWtleV8wMTg1ZWI2Yi0yN2ZjLTQ0MjgtYjA3Zi1lMmQxOWFlNjU4ZWMiLCJhbGciOiJIUzI1NiJ9.eyJ1cmwiOiJsb2dvcy9sb2dvTGFwd2FyZUxpZ2h0LnBuZyIsImlhdCI6MTc3NTIzNDIyMSwiZXhwIjoyNTYzNjM0MjIxfQ.ufuiPynZ0CjXwWPudmCMb3h1OCD1vnDA0Bbdc6AzrTo'
            alt='Lapwing Software'
            width='128'
            height='128'
            class='mx-auto block w-24 rounded-xl sm:w-28'
          />
        </div>

        <div class='px-6 pb-4 pt-6 text-center sm:px-8'>
          <h1
            class='m-0 font-heading text-3xl font-extrabold tracking-tight text-[#0A0F0A] sm:text-4xl'
          >
            Email Confirmed
          </h1>

          <p
            class='mx-auto mt-4 max-w-md text-base leading-relaxed text-[#6E7A71]'
          >
            Your email address has been verified successfully. You can now start
            planning meals, tracking ingredients, and building your smarter
            pantry with Kippr.
          </p>
        </div>

        <footer
          class='border-t border-[#6E7A711a] bg-[#EBF5EE] px-6 py-6 text-center sm:px-8'
        >
          <p class='m-0 text-xs text-[#6E7A71]'>&copy; Lapwing Software</p>

          <p class='mt-2 text-xs'>
            <a
              href='/kippr/privacy-policy'
              class='font-medium text-[#1E914B] no-underline hover:underline'
            >
              Privacy Policy
            </a>
            <span class='mx-2 text-[#6E7A71]'>|</span>
            <a
              href='/kippr/terms-and-conditions'
              class='font-medium text-[#1E914B] no-underline hover:underline'
            >
              Terms &amp; Conditions
            </a>
          </p>
        </footer>
      </section>
    </main>
  </body>
</html>
